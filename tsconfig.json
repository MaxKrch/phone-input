{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "react-jsx",
        "lib": ["ESNext", "DOM"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@demo/*": ["./src/demo/*"],
            "@components/*": ["./src/components/*"],
            "@store/*": ["./src/store/*"],
            "@shared/*": ["./src/shared/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules"]
}