{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "react-jsx",
        "lib": ["ESNext", "DOM"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "demo/*": ["./src/demo/*"],
            "features/*": ["./src/features/*"],
            "store/*": ["./src/store/*"],
            "shared/*": ["./src/shared/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules"]
}